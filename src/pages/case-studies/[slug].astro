---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CaseStudyCard from "../../components/CaseStudyCard.astro";
import { caseStudies, getRelated } from "../../data/caseStudies";

export async function getStaticPaths() {
  return caseStudies.map((c) => ({ params: { slug: c.slug }, props: { study: c } }));
}

const { study } = Astro.props;
const related = getRelated(study.slug, 3);
---
<BaseLayout title={`${study.name} — Case Study | lowercase b2b`} description={study.subhead}>
  <!-- HERO -->
  <section class="px-6 sm:px-12 lg:px-20 pt-32 sm:pt-48 pb-16">
    <p class="font-mono text-[12px] tracking-[0.15em] text-muted uppercase">
      <span class="text-accent">●</span> {study.category}
    </p>
    <h1 class="mt-6 max-w-[1040px]">{study.headline}</h1>
    <p class="mt-6 max-w-[820px] text-[18px] leading-relaxed text-ink/80">{study.subhead}</p>
    <p class="mt-8 font-mono text-[11px] tracking-[0.1em] text-muted uppercase">{study.services}</p>
  </section>

  <!-- VIDEO -->
  <section class="px-6 sm:px-12 lg:px-20 pb-24">
    <div class="relative w-full aspect-video rounded-sm overflow-hidden bg-panel">
      <iframe
        class="absolute inset-0 w-full h-full"
        src={`https://www.youtube.com/embed/${study.youtubeId}`}
        title={`${study.name} case study video`}
        frameborder="0"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
        referrerpolicy="strict-origin-when-cross-origin"
        allowfullscreen
      />
    </div>
  </section>

  <!-- STATS -->
  <section class="px-6 sm:px-12 lg:px-20 pb-32">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      {study.stats.map((s, i) => (
        <div class="border border-line p-8 min-h-[200px] flex flex-col justify-between rounded-sm">
          <span class="font-mono text-[11px] text-muted">{String(i + 1).padStart(2, "0")} —</span>
          <div>
            <div class="text-[48px] sm:text-[56px] tracking-[-0.03em] font-light leading-none">{s.value}</div>
            <p class="mt-3 text-[14px] text-ink/70 leading-relaxed">{s.label}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- ARTICLE + TOC -->
  <section class="px-6 sm:px-12 lg:px-20 pb-32">
    <div class="grid grid-cols-1 lg:grid-cols-[260px_1fr] gap-12 lg:gap-20">
      <aside class="lg:sticky lg:top-24 self-start space-y-8">
        <div>
          <p class="font-mono text-[11px] tracking-[0.15em] text-muted uppercase mb-4">— Contents</p>
          <nav class="case-toc flex flex-col space-y-2 font-mono text-[12px] tracking-tight">
            {study.toc.map((t) => (
              <a href={`#${t.id}`} data-toc={t.id} class="toc-link block py-1 text-[#404040] hover:text-ink transition">
                {t.label}
              </a>
            ))}
          </nav>
        </div>

        <aside class="bg-panel text-white p-6 rounded-sm">
          <p class="font-mono text-[10px] tracking-[0.15em] text-white/60 uppercase">
            <span class="text-accent">●</span> Newsletter
          </p>
          <h3 class="mt-3 text-[20px] tracking-[-0.01em] font-light leading-snug">
            Get the next case study in your inbox.
          </h3>
          <p class="mt-3 text-[13px] text-white/70 leading-relaxed">
            One note a month on B2B GTM — positioning, SEO, AI search, and the brands we admire.
          </p>
          <form class="email-capture mt-5 w-full" data-source={`${Astro.url.pathname}#newsletter-aside`} data-cal="https://cal.com/rikin-diwan/lowercase-intro">
            <label for={`newsletter-${study.slug}`} class="sr-only">Work email</label>
            <input
              id={`newsletter-${study.slug}`}
              type="email"
              name="email"
              required
              placeholder="emma@email.com"
              autocomplete="email"
              class="w-full bg-transparent border border-white/20 px-3 py-2.5 text-[13px] text-white placeholder:text-white/40 focus:outline-none focus:border-white rounded-sm"
            />
            <button
              type="submit"
              class="mt-2 w-full font-mono text-[10px] tracking-[0.15em] uppercase bg-white text-panel px-4 py-2.5 rounded-sm hover:opacity-90 transition disabled:opacity-60"
            >
              Subscribe
            </button>
          </form>
        </aside>
      </aside>
      <article class="max-w-[720px] space-y-16">
        {study.article.map((sec) => (
          <div id={sec.id} class="scroll-mt-24">
            <h2 class="text-[28px] sm:text-[32px] tracking-[-0.02em] font-light">{sec.heading}</h2>
            <div class="mt-6 space-y-5 text-[16px] leading-relaxed text-ink/80">
              {sec.body.map((p) => <p>{p}</p>)}
            </div>
          </div>
        ))}
      </article>
    </div>
  </section>

  <!-- RELATED -->
  <section class="px-6 sm:px-12 lg:px-20 py-32">
    <div class="flex justify-between items-baseline mb-12">
      <h2 class="text-[28px] sm:text-[36px] tracking-[-0.02em] font-light">More case studies.</h2>
      <a href="/case-studies" class="font-mono text-[11px] tracking-[0.15em] text-muted hover:text-ink">— VIEW ALL</a>
    </div>
    <div class="grid gap-4 grid-cols-1 sm:grid-cols-2 lg:grid-cols-3">
      {related.map((c) => (
        <CaseStudyCard
          slug={c.slug}
          name={c.name}
          category={c.category}
          services={c.services}
          media={c.media}
        />
      ))}
    </div>
  </section>
</BaseLayout>

<script>
  const links = document.querySelectorAll<HTMLAnchorElement>(".toc-link");
  if (links.length) {
    const sections = Array.from(links)
      .map((l) => document.getElementById(l.dataset.toc || ""))
      .filter((el): el is HTMLElement => !!el);
    const setActive = (id: string) => {
      links.forEach((l) => {
        const active = l.dataset.toc === id;
        l.classList.toggle("text-accent", active);
        l.classList.toggle("text-[#404040]", !active);
      });
    };
    const io = new IntersectionObserver(
      (entries) => {
        const visible = entries.filter((e) => e.isIntersecting).sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);
        if (visible[0]) setActive(visible[0].target.id);
      },
      { rootMargin: "-30% 0px -60% 0px", threshold: 0 }
    );
    sections.forEach((s) => io.observe(s));
  }
</script>
