---
import { Icon } from "astro-icon/components";

type CardNode = { id: string; x: number; y: number; w: number; h: number; icon: string; glow?: boolean };
type LogoNode = { id: string; x: number; y: number; w: number; h: number; src: string; alt: string };
type CircleNode = { id: string; x: number; y: number; r: number; src: string; alt: string };

const VB_W = 1000;
const VB_H = 540;

const TRACE_DUR = 4;
const TRACE_X0 = 60;
const TRACE_X1 = 920;

const cards: CardNode[] = [
  { id: "play",   x: 60,  y: 60,  w: 80,  h: 80, icon: "ph:atom",        glow: true },
  { id: "kb",     x: 240, y: 60,  w: 80,  h: 80, icon: "ph:stack-plus",  glow: true },
  { id: "ai",     x: 440, y: 60,  w: 80,  h: 80, icon: "ph:sparkle",     glow: true },
  { id: "edit1",  x: 600, y: 60,  w: 80,  h: 80, icon: "ph:note-pencil", glow: true },
  { id: "pub1",   x: 760, y: 60,  w: 80,  h: 80, icon: "ph:lightning",   glow: true },
  { id: "cube",   x: 440, y: 380, w: 80,  h: 80, icon: "ph:cube" },
  { id: "edit2",  x: 600, y: 290, w: 80,  h: 80, icon: "ph:note-pencil" },
  { id: "pub2",   x: 760, y: 290, w: 80,  h: 80, icon: "ph:lightning" },
  { id: "edit3",  x: 600, y: 410, w: 80,  h: 80, icon: "ph:note-pencil" },
  { id: "pub3",   x: 760, y: 410, w: 80,  h: 80, icon: "ph:lightning" },
];

const logos: LogoNode[] = [
  { id: "webflow",  x: 925, y: 85,  w: 30, h: 30, src: "/logos-cms/webflow.svg",  alt: "Webflow" },
  { id: "framer",   x: 925, y: 175, w: 30, h: 30, src: "/logos-cms/framer.svg",   alt: "Framer" },
  { id: "x",        x: 925, y: 315, w: 30, h: 30, src: "/logos-cms/x.svg",        alt: "X" },
  { id: "linkedin", x: 925, y: 435, w: 30, h: 30, src: "/logos-cms/linkedin.svg", alt: "LinkedIn" },
];

const circles: CircleNode[] = [
  { id: "openai",    x: 235, y: 420, r: 35, src: "/logos-cms/openai.svg", alt: "OpenAI" },
  { id: "anthropic", x: 325, y: 420, r: 35, src: "/logos-cms/claude.svg", alt: "Claude" },
];

const glowDelay = (centerX: number) => {
  const t = ((centerX - TRACE_X0) / (TRACE_X1 - TRACE_X0)) * TRACE_DUR;
  return `${(t - TRACE_DUR).toFixed(2)}s`;
};
---
<div class="pipeline" role="img" aria-label="Content production pipeline">
  <svg class="pipeline-svg" viewBox={`0 0 ${VB_W} ${VB_H}`} preserveAspectRatio="xMidYMid meet" aria-hidden="true">
    <g stroke="#c8c8c4" stroke-width="1" fill="none">
      <!-- top horizontal flow (continuous, no arrowheads) -->
      <line x1="60" y1="100" x2="920" y2="100" />

      <!-- branch from pub1 to framer -->
      <path d="M800,140 C 840,140 880,190 920,190" />

      <!-- AI inputs (dashed) into knowledge base -->
      <path d="M235,385 C 235,300 250,200 270,145" stroke-dasharray="4 4" />
      <path d="M325,385 C 325,310 310,210 290,145" stroke-dasharray="4 4" />

      <!-- cube (prompt) up to sparkle -->
      <path d="M480,380 C 480,300 480,220 480,145" stroke-dasharray="4 4" />

      <!-- ai sparkle splits down to edit2 and edit3 -->
      <path d="M510,130 C 555,130 555,330 600,330" />
      <path d="M510,130 C 560,130 555,450 600,450" />

      <!-- row 2: edit2 -> pub2 -> x -->
      <line x1="600" y1="330" x2="920" y2="330" />

      <!-- row 3: edit3 -> pub3 -> linkedin -->
      <line x1="600" y1="450" x2="920" y2="450" />
    </g>

    <g fill="none" stroke="#ff6d12" stroke-width="1.6" stroke-linecap="round">
      <path
        class="trace"
        d="M60,100 L920,100"
        pathLength="100"
        stroke-dasharray="6 94"
      />
      <path
        class="trace trace-branch"
        d="M510,130 C 555,130 555,330 600,330 L920,330"
        pathLength="100"
        stroke-dasharray="6 94"
      />
      <path
        class="trace trace-branch"
        d="M510,130 C 560,130 555,450 600,450 L920,450"
        pathLength="100"
        stroke-dasharray="6 94"
      />
    </g>
  </svg>

  {cards.map((n) => {
    const cx = n.x + n.w / 2;
    const style = `left:${(n.x / VB_W) * 100}%; top:${(n.y / VB_H) * 100}%; width:${(n.w / VB_W) * 100}%; aspect-ratio:${n.w}/${n.h};${n.glow ? ` --glow-delay:${glowDelay(cx)};` : ""}`;
    return (
      <div class:list={["node", "card", n.glow && "card-pulse"]} style={style}>
        <Icon name={n.icon} />
      </div>
    );
  })}

  {logos.map((n) => (
    <div
      class="node logo"
      aria-label={n.alt}
      style={`left:${(n.x / VB_W) * 100}%; top:${(n.y / VB_H) * 100}%; width:${(n.w / VB_W) * 100}%; aspect-ratio:${n.w}/${n.h};`}
    >
      <img src={n.src} alt={n.alt} />
    </div>
  ))}

  {circles.map((n) => (
    <div
      class="node circle"
      aria-label={n.alt}
      style={`left:${((n.x - n.r) / VB_W) * 100}%; top:${((n.y - n.r) / VB_H) * 100}%; width:${((n.r * 2) / VB_W) * 100}%; aspect-ratio:1;`}
    >
      <img src={n.src} alt={n.alt} />
    </div>
  ))}
</div>

<style>
  .pipeline {
    position: relative;
    width: 100%;
    aspect-ratio: 1000 / 540;
    max-width: 820px;
    margin: 0 auto;
  }
  .pipeline-svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    color: #c8c8c4;
  }
  .trace {
    animation: trace-flow 4s linear infinite;
  }
  .trace-branch {
    animation-name: trace-flow-branch;
    animation-duration: 8s;
    animation-delay: 1.95s;
  }
  @keyframes trace-flow {
    from { stroke-dashoffset: 100; }
    to   { stroke-dashoffset: 0; }
  }
  @keyframes trace-flow-branch {
    0%   { stroke-dashoffset: 100; opacity: 1; }
    50%  { stroke-dashoffset: 0; opacity: 1; }
    50.01% { opacity: 0; }
    100% { stroke-dashoffset: 0; opacity: 0; }
  }
  .node {
    position: absolute;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .card {
    --card-shadow:
      0 1px 1px rgba(0,0,0,0.03),
      0 6px 18px rgba(0,0,0,0.05),
      inset 0 0 0 1px rgba(0,0,0,0.03);
    background: #fff;
    border-radius: 8px;
    box-shadow: var(--card-shadow);
    color: #6b6b66;
  }
  .card :global(svg) {
    width: 36%;
    height: 36%;
  }
  .card-pulse {
    animation: card-glow 4s linear infinite;
    animation-delay: var(--glow-delay, 0s);
  }
  @keyframes card-glow {
    0%   { box-shadow: 0 0 16px 2px rgba(255,109,18,0.18), var(--card-shadow); }
    30%  { box-shadow: 0 0 0 0 rgba(255,109,18,0), var(--card-shadow); }
    100% { box-shadow: 0 0 0 0 rgba(255,109,18,0), var(--card-shadow); }
  }
  .circle {
    background: #fff;
    border-radius: 999px;
    box-sizing: border-box;
    box-shadow:
      0 1px 1px rgba(0,0,0,0.03),
      0 6px 18px rgba(0,0,0,0.05),
      inset 0 0 0 1px rgba(0,0,0,0.04);
  }
  .circle img {
    width: 38%;
    height: 38%;
    object-fit: contain;
    opacity: 0.7;
    filter: grayscale(100%);
  }
  .logo {
    background: transparent;
  }
  .logo img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    opacity: 0.55;
    filter: grayscale(100%);
  }
  @media (prefers-reduced-motion: reduce) {
    .trace { animation: none; opacity: 0; }
    .card-pulse { animation: none; }
  }
</style>
