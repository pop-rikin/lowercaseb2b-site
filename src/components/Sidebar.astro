---
import Logo from "./Logo.astro";
const { pathname } = Astro.url;
const isActive = (href: string) =>
  href === "/" ? pathname === "/" : pathname.startsWith(href);

const nav = [
  {
    label: "Services",
    href: "/services/seo",
    children: [
      { label: "SEO & Content", href: "/services/seo" },
      { label: "Web Dev & Design", href: "/services/web-design" },
      { label: "Product Positioning", href: "/services/product-positioning" },
    ],
  },
  { label: "Work", href: "/clients" },
  { label: "Writing", href: "https://rikin.substack.com", external: true },
  { label: "Connect", href: "https://www.linkedin.com/in/rikin/", external: true },
];

const showSubnav = pathname.startsWith("/services/");
---
<aside transition:persist="sidebar" class="fixed inset-y-0 left-0 z-30 hidden md:flex w-[200px] flex-col border-r border-[#f0f0ec] bg-bg px-5 py-6" data-pathname={pathname}>
  <Logo />
  <nav class="flex-1 flex flex-col justify-center font-mono text-[13px] tracking-tight space-y-3">
    {nav.map((item) => (
      <div>
        <a
          href={item.href}
          data-href={item.href}
          target={item.external ? "_blank" : undefined}
          rel={item.external ? "noreferrer" : undefined}
          class:list={[
            "nav-link block py-1 transition",
            isActive(item.href) ? "text-accent" : "text-[#404040] hover:text-ink",
          ]}
        >
          {item.label}
        </a>
        {item.children && (
          <div
            class="subnav-wrap overflow-hidden transition-[grid-template-rows,opacity] duration-300 ease-[cubic-bezier(0.22,1,0.36,1)] grid"
            data-parent="/services/"
            style={pathname.startsWith("/services/") ? "grid-template-rows:1fr;opacity:1" : "grid-template-rows:0fr;opacity:0"}
          >
            <div class="min-h-0">
              <div class="subnav mt-1 ml-3 space-y-1 border-l border-line pl-3">
                {item.children.map((sub, i) => (
                  <a
                    href={sub.href}
                    data-href={sub.href}
                    style={`--i:${i}`}
                    class:list={[
                      "subnav-item nav-link block py-1 text-[12px]",
                      pathname === sub.href ? "text-accent" : "text-[#404040] hover:text-ink",
                    ]}
                  >
                    {sub.label}
                  </a>
                ))}
              </div>
            </div>
          </div>
        )}
      </div>
    ))}
  </nav>

  <a
    href="https://cal.com/rikin-diwan/lowercase-intro" target="_blank" rel="noreferrer"
    class="block text-center font-mono text-[11px] tracking-[0.15em] uppercase bg-accent text-white py-3 rounded-sm hover:opacity-90 transition"
  >
    Let's Talk
  </a>
</aside>

<style>
  @keyframes subnav-expand {
    from { opacity: 0; transform: scaleY(0.85); max-height: 0; }
    to   { opacity: 1; transform: scaleY(1); max-height: 200px; }
  }
  @keyframes subnav-item-in {
    from { opacity: 0; transform: translateX(-6px); }
    to   { opacity: 1; transform: translateX(0); }
  }
  .subnav {
    transform-origin: top;
    animation: subnav-expand 300ms cubic-bezier(0.22, 1, 0.36, 1) both;
  }
  .subnav-item {
    animation: subnav-item-in 300ms cubic-bezier(0.22, 1, 0.36, 1) both;
    animation-delay: calc(80ms + var(--i) * 60ms);
  }
  @media (prefers-reduced-motion: reduce) {
    .subnav, .subnav-item { animation: none; }
  }

</style>

<header transition:persist="mobile-header" class="md:hidden sticky top-0 z-40 flex items-center justify-between px-5 py-4 border-b border-[#f0f0ec] bg-bg">
  <Logo />
  <div class="flex items-center gap-3">
    <a href="https://cal.com/rikin-diwan/lowercase-intro" target="_blank" rel="noreferrer" class="font-mono text-[11px] tracking-[0.15em] uppercase bg-accent text-white px-4 py-2 rounded-sm">Let's Talk</a>
    <button type="button" class="mobile-menu-btn flex items-center justify-center w-9 h-9" aria-label="Open menu" aria-expanded="false">
      <span class="dot-grid inline-grid grid-cols-3 grid-rows-3 gap-[3px]">
        <span class="w-[2px] h-[2px] rounded-full bg-ink"></span>
        <span class="w-[2px] h-[2px] rounded-full bg-ink"></span>
        <span class="w-[2px] h-[2px] rounded-full bg-ink"></span>
        <span class="w-[2px] h-[2px] rounded-full bg-ink"></span>
        <span class="w-[2px] h-[2px] rounded-full bg-ink"></span>
        <span class="w-[2px] h-[2px] rounded-full bg-ink"></span>
        <span class="w-[2px] h-[2px] rounded-full bg-ink"></span>
        <span class="w-[2px] h-[2px] rounded-full bg-ink"></span>
        <span class="w-[2px] h-[2px] rounded-full bg-ink"></span>
      </span>
    </button>
  </div>
</header>

<div class="mobile-menu fixed inset-0 z-50 hidden md:hidden bg-bg opacity-0 transition-opacity duration-300 flex flex-col">
  <div class="flex items-center justify-between px-5 py-4 border-b border-[#f0f0ec]">
    <Logo />
    <button type="button" class="mobile-menu-close flex items-center justify-center w-9 h-9" aria-label="Close menu">
      <span class="dot-grid inline-grid grid-cols-3 grid-rows-3 gap-[3px]">
        <span class="w-[2px] h-[2px] rounded-full bg-ink"></span>
        <span class="w-[2px] h-[2px] rounded-full bg-transparent"></span>
        <span class="w-[2px] h-[2px] rounded-full bg-ink"></span>
        <span class="w-[2px] h-[2px] rounded-full bg-transparent"></span>
        <span class="w-[2px] h-[2px] rounded-full bg-ink"></span>
        <span class="w-[2px] h-[2px] rounded-full bg-transparent"></span>
        <span class="w-[2px] h-[2px] rounded-full bg-ink"></span>
        <span class="w-[2px] h-[2px] rounded-full bg-transparent"></span>
        <span class="w-[2px] h-[2px] rounded-full bg-ink"></span>
      </span>
    </button>
  </div>
  <nav class="flex-1 flex flex-col justify-center px-8 font-mono tracking-tight space-y-6">
    {nav.map((item) => (
      <div>
        <a
          href={item.href}
          target={item.external ? "_blank" : undefined}
          rel={item.external ? "noreferrer" : undefined}
          class:list={[
            "block py-1 text-[28px] font-light",
            isActive(item.href) ? "text-accent" : "text-ink",
          ]}
        >
          {item.label}
        </a>
        {item.children && (
          <div class="mt-2 ml-4 space-y-2 border-l border-line pl-4">
            {item.children.map((sub) => (
              <a
                href={sub.href}
                class:list={[
                  "block py-1 text-[15px]",
                  pathname === sub.href ? "text-accent" : "text-[#404040]",
                ]}
              >
                {sub.label}
              </a>
            ))}
          </div>
        )}
      </div>
    ))}
  </nav>
  <div class="px-8 pb-10">
    <a
      href="https://cal.com/rikin-diwan/lowercase-intro" target="_blank" rel="noreferrer"
      class="block text-center font-mono text-[11px] tracking-[0.15em] uppercase bg-accent text-white py-4 rounded-sm"
    >
      Let's Talk
    </a>
  </div>
</div>

<script>
  const wireMobileMenu = () => {
    const menu = document.querySelector<HTMLElement>(".mobile-menu");
    const btn = document.querySelector<HTMLButtonElement>(".mobile-menu-btn");
    const closeBtn = document.querySelector<HTMLButtonElement>(".mobile-menu-close");
    if (!menu || !btn) return;
    const open = () => {
      menu.classList.remove("hidden");
      requestAnimationFrame(() => menu.classList.remove("opacity-0"));
      btn.setAttribute("aria-expanded", "true");
      document.body.style.overflow = "hidden";
    };
    const close = () => {
      menu.classList.add("opacity-0");
      btn.setAttribute("aria-expanded", "false");
      document.body.style.overflow = "";
      setTimeout(() => menu.classList.add("hidden"), 300);
    };
    btn.addEventListener("click", open);
    closeBtn?.addEventListener("click", close);
    menu.querySelectorAll<HTMLAnchorElement>("a").forEach((a) => a.addEventListener("click", close));
  };

  const syncSidebar = () => {
    const path = window.location.pathname;
    document.querySelectorAll<HTMLElement>("aside [data-href], aside [data-href] *").forEach(() => {});
    document.querySelectorAll<HTMLAnchorElement>(".nav-link").forEach((link) => {
      const href = link.dataset.href || "";
      const isSub = link.classList.contains("subnav-item");
      const active = isSub ? path === href : (href === "/" ? path === "/" : path.startsWith(href));
      link.classList.toggle("text-accent", active);
      link.classList.toggle("text-[#404040]", !active);
    });
    document.querySelectorAll<HTMLElement>(".subnav-wrap").forEach((wrap) => {
      const parent = wrap.dataset.parent || "";
      const open = path.startsWith(parent);
      wrap.style.gridTemplateRows = open ? "1fr" : "0fr";
      wrap.style.opacity = open ? "1" : "0";
    });
  };

  wireMobileMenu();
  syncSidebar();
  document.addEventListener("astro:after-swap", syncSidebar);
</script>
