---
import BaseLayout from "../../layouts/BaseLayout.astro";
import EmailCapture from "../../components/EmailCapture.astro";
import LogoStrip from "../../components/LogoStrip.astro";
import ContentPipeline from "../../components/ContentPipeline.astro";
import WorkSection from "../../components/WorkSection.astro";
import { Icon } from "astro-icon/components";

const evolutionRows = [
  [
    { label: "GEO", icon: "ph:robot" },
    { label: "Speech > Text", icon: "ph:microphone" },
    { label: "Case Studies", icon: "ph:read-cv-logo" },
    { label: "Video Search", icon: "ph:play-circle" },
  ],
  [
    { label: "Programmatic Content", icon: "ph:code" },
    { label: "AI SERP Features", icon: "ph:sparkle" },
    { label: "Lead Magnets", icon: "ph:magnet" },
  ],
];

const stats = [
  { n: "2-5x", label: "Monthly Content Production" },
  { n: "1M+", label: "Search & LLM Visits/Mo Managed" },
  { n: "10x", label: "Organic Keywords" },
];

const phases = [
  { title: "Knowledge Base", body: "We build a single source-of-truth that powers and refines all future content. Designed for collaboration and to be increasingly intelligent as we continuously intake more information." },
  { title: "Audit & Strategy", body: "We don't believe in random acts of content. Instead, we create the most complete SEO audit. Identify your content opportunity, benchmark competitor content investments, and design a 6+ month content roadmap." },
  { title: "Architecture", body: "Pretty websites suck. We optimize your site for search and LLM crawlers by re-architecting your sitemap, key UX components, and internal-linking strategy." },
  { title: "Execution", body: "High quality and high volume content creation by combining expert editors with powerful AI workflows. We start with strategy & content creation all the way through publishing on your CMS of choice." },
  { title: "Refinement", body: "Monthly SEO audits to identify opportunities for improved rankings and increased organic traffic with both new and optimized content." },
];

const customized = ["Monthly Content Production","Programmatic Content/Directory Production","Off-page GEO Mentions","Traditional SEO Backlinking","Newsletters","Technical SEO Maintenance","Content & Competitive Audits","SEO Strategy & Optimizations"];
const howWeWork = ["Flexible Terms","Dedicated Strategist","B2B Experienced Editors","Slack Channel","Notion Project Trackers","Weekly/Bi-Weekly Stand Ups"];

const testimonials = [
  { quote: "Rikin and the lowercase team are insanely good at SEO. They completely wowed us — so much so that we've started working with lowercase instead of our previous provider.", who: "Monty Ngan, Cofounder of Pearl Talent" },
  { quote: "It feels like you actually understand our business - we've worked with many agencies in the past and that is rare.", who: "Dan Pantelo, Founder & CEO of Marpipe" },
  { quote: "You can tell the lowercase team is built differently. They've been in-house at companies in our industry and it shows in their obsession over impact and quality.", who: "Dean Ginsburg, Founder of Winback" },
  { quote: "When we needed to reposition our entire GTM process, lowercase effortlessly led us through a rebrand and an entirely new site build.", who: "Amit Patel, Founder, Perform" },
];
---
<BaseLayout title="SEO & AEO agency for B2B startups.">
  <!-- announcement banner -->
  <div class="border-b border-line px-6 sm:px-12 py-3 font-mono text-[11px] tracking-tight">
    <span class="text-accent">● NEW</span>
    <span class="ml-2">lowercase partners with Geostar.ai and Gumshoe.ai to optimize B2B for GEO</span>
  </div>

  <section class="px-6 sm:px-12 lg:px-20 pt-24 sm:pt-32 pb-24">
    <h1 class="max-w-[1040px]">
      SEO &amp; AEO for the AI era
    </h1>
    <p class="mt-6 max-w-[680px] text-[16px] leading-relaxed text-ink/80">
      Combining the best B2B content creators with powerful AI workflows. Driving 1M+ organic visitors per month.
    </p>
    <div class="mt-12">
      <EmailCapture />
    </div>
  </section>

  <LogoStrip />

  <!-- evolution -->
  <section class="px-6 sm:px-12 lg:px-20 py-32 text-center">
    <h2 class="text-[28px] sm:text-[36px] tracking-[-0.02em] font-light max-w-[920px] mx-auto">Content creation &amp; distribution has evolved.</h2>
    <p class="mt-6 max-w-[820px] mx-auto text-ink/80">Companies need a methodical content approach designed for search engines and LLM crawlers.</p>
    <div class="mt-16 space-y-3 max-w-[1040px] mx-auto">
      {evolutionRows.map((row) => (
        <div class="flex flex-wrap justify-center gap-3">
          {row.map((tag) => (
            <span class="inline-flex items-center gap-2 px-4 py-2 border border-line font-mono text-[12px] tracking-tight rounded-sm">
              <Icon name={tag.icon} class="w-4 h-4 text-accent" />
              {tag.label}
            </span>
          ))}
        </div>
      ))}
    </div>
  </section>

  <!-- engineers -->
  <section class="px-6 sm:px-12 lg:px-20 py-32">
    <h2 class="text-[28px] sm:text-[36px] tracking-[-0.02em] font-light">We're content engineers.</h2>
    <p class="mt-6 max-w-[820px] text-ink/80">
      The latest strategies, custom AI agents, and expert human editors delivering authoritative content on brand and at scale.
    </p>
    <div class="mt-20">
      <ContentPipeline />
    </div>
  </section>

  <!-- proven success / stats -->
  <section class="bg-panel text-white px-6 sm:px-12 lg:px-20 py-32">
    <h2 class="text-[28px] sm:text-[36px] tracking-[-0.02em] font-light">Proven success.</h2>
    <p class="mt-3 text-white/70">Proud to boast a 95% customer retention rate.</p>
    <div class="mt-16 grid grid-cols-1 sm:grid-cols-3 gap-px bg-white/10 border border-white/10">
      {stats.map((s) => (
        <div class="bg-panel p-12 min-h-[220px] flex flex-col justify-between">
          <span class="text-[64px] sm:text-[80px] tracking-[-0.04em] font-light leading-none">{s.n}</span>
          <span class="font-mono text-[11px] tracking-[0.15em] uppercase text-white/60">{s.label}</span>
        </div>
      ))}
    </div>
    <div class="mt-12 flex justify-center">
      <a href="https://cal.com/rikin-diwan/lowercase-intro" target="_blank" rel="noreferrer" class="inline-block bg-white text-panel font-mono text-[11px] tracking-[0.15em] uppercase px-8 py-3 rounded-sm">Let's Talk</a>
    </div>
  </section>

  <!-- process -->
  <section class="px-6 sm:px-12 lg:px-20 py-32">
    <h2 class="text-[28px] sm:text-[36px] tracking-[-0.02em] font-light">The process.</h2>
    <p class="mt-6 max-w-[820px] text-ink/80">
      We bring a product mindset to content creation — custom tooling and systems evolved over numerous engagements with startups in scale mode.
    </p>
    <div class="mt-16 space-y-px bg-line border border-line">
      {phases.map((p, i) => (
        <div class="bg-bg p-8 grid grid-cols-1 lg:grid-cols-[200px_1fr] gap-6">
          <div>
            <span class="font-mono text-[11px] text-muted">0{i + 1} —</span>
            <h3 class="mt-2 text-[22px] tracking-tight font-light">{p.title}</h3>
          </div>
          <p class="text-[15px] text-ink/80 leading-relaxed max-w-[720px]">{p.body}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- pull quote -->
  <section class="px-6 sm:px-12 lg:px-20 py-32">
    <blockquote class="text-[28px] sm:text-[36px] leading-snug font-light tracking-tight max-w-[1040px]">
      "Many agencies have audited our site before — lowercase's SEO audit and strategy is the best we've ever seen."
    </blockquote>
    <div class="mt-8 flex items-center gap-3">
      <img src="/images/aly-murray.png" alt="Aly Murray" width="32" height="32" class="w-8 h-8 rounded-full object-cover" />
      <p class="font-mono text-[11px] tracking-tight text-muted">Aly Murray, CEO of UPchieve</p>
    </div>
  </section>

  <!-- case study highlight -->
  <section class="px-6 sm:px-12 lg:px-20 py-32">
    <div class="grid grid-cols-1 lg:grid-cols-2 border border-line rounded-sm overflow-hidden">
      <div class="bg-bg p-10 sm:p-12 flex flex-col">
        <h2 class="text-[28px] sm:text-[36px] leading-[1.15] tracking-[-0.02em] font-light max-w-[520px]">
          How Marpipe dominated its target keywords and grew organic traffic 5x in 12 months
        </h2>
        <p class="mt-6 text-[15px] text-ink/80 leading-relaxed max-w-[560px]">
          Marpipe is in the business of "Catalog Ads" — so we made it our mission to get them into the top 3 ranking sites for the term. Through a focused SEO and AI-search strategy, we now own the category SERP, with 185 keywords ranking in the top 3 and organic traffic 5x'd in 12 months.
        </p>
        <div class="mt-10 grid grid-cols-2 gap-4">
          <div class="border border-dashed border-line p-6 rounded-sm">
            <p class="text-[28px] sm:text-[32px] tracking-[-0.02em] font-light leading-none">5x</p>
            <p class="mt-3 font-mono text-[11px] tracking-tight text-muted">organic traffic growth in 12 months</p>
          </div>
          <div class="border border-dashed border-line p-6 rounded-sm">
            <p class="text-[28px] sm:text-[32px] tracking-[-0.02em] font-light leading-none">6.2K</p>
            <p class="mt-3 font-mono text-[11px] tracking-tight text-muted">monthly organic visits</p>
          </div>
          <div class="border border-dashed border-line p-6 rounded-sm col-span-2">
            <p class="text-[28px] sm:text-[32px] tracking-[-0.02em] font-light leading-none">$1.1M</p>
            <p class="mt-3 font-mono text-[11px] tracking-tight text-muted">monthly organic traffic value (Ahrefs equivalent)</p>
          </div>
        </div>
      </div>
      <div class="bg-accent text-white p-6 sm:p-8 flex flex-col">
        <div class="flex items-center justify-center gap-4">
          <span class="h-px flex-1 bg-white/40"></span>
          <img src="/logos/marpipe.svg" alt="Marpipe" class="h-5 w-auto brightness-0 invert" />
          <span class="h-px flex-1 bg-white/40"></span>
        </div>
        <div class="mt-6 relative flex-1 min-h-[320px] rounded-sm overflow-hidden bg-panel border border-white/20">
          <img src="/images/dan-pantelo-marpipe.png" alt="Marpipe case study" class="absolute inset-0 w-full h-full object-cover" />
          <div class="absolute bottom-4 left-4 font-mono text-[11px] tracking-tight">
            <span class="block text-white/70">Founder & CEO — Marpipe</span>
            <span class="block text-[22px] font-light leading-tight">Dan Pantelo</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- pricing -->
  <section class="px-6 sm:px-12 lg:px-20 py-32">
    <h2 class="text-[28px] sm:text-[36px] tracking-[-0.02em] font-light">Let's get started.</h2>
    <p class="mt-6 max-w-[820px] text-ink/80">Plans and pricing built for startups looking to scale way beyond the PMF stage.</p>
    <div class="mt-12 border border-line p-8 sm:p-12 max-w-[1040px] rounded-sm">
      <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-4">
        <h3 class="text-[24px] tracking-tight font-light max-w-[640px]">SEO &amp; GEO Strategy, Content Creation, &amp; Optimizations</h3>
        <p class="font-mono text-[14px] tracking-tight">Starting at <span class="text-[24px] font-light">$6,000/mo</span></p>
      </div>
      <div class="mt-10 grid grid-cols-1 sm:grid-cols-2 gap-12">
        <div>
          <p class="font-mono text-[11px] tracking-[0.15em] text-muted uppercase">Customized Services</p>
          <ul class="mt-4 space-y-2 text-[15px] text-ink/80">
            {customized.map((s) => <li>— {s}</li>)}
          </ul>
        </div>
        <div>
          <p class="font-mono text-[11px] tracking-[0.15em] text-muted uppercase">How We Work</p>
          <ul class="mt-4 space-y-2 text-[15px] text-ink/80">
            {howWeWork.map((s) => <li>— {s}</li>)}
          </ul>
        </div>
      </div>
      <a href="https://cal.com/rikin-diwan/lowercase-intro" target="_blank" rel="noreferrer" class="mt-10 inline-block bg-panel text-white font-mono text-[11px] tracking-[0.15em] uppercase px-8 py-3 rounded-sm">Let's Talk</a>
    </div>
  </section>

  <WorkSection />
</BaseLayout>
