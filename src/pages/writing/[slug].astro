---
import BaseLayout from "../../layouts/BaseLayout.astro";
import BlogPostCard from "../../components/BlogPostCard.astro";
import { Image } from "astro:assets";
import rikinHeadshot from "../../assets/headshots/rikin-diwan.png";
import { posts, getRelatedPosts, formatDate } from "../../data/posts";

export async function getStaticPaths() {
  return posts.map((p) => ({ params: { slug: p.slug }, props: { post: p } }));
}

const { post } = Astro.props;
const related = getRelatedPosts(post.slug, 3);

const authorUrl = "https://www.linkedin.com/in/rikin/";
const siteUrl = "https://lowercaseb2b.com";
const canonical = `${siteUrl}${Astro.url.pathname.replace(/\/$/, "")}`;
const authorImageUrl = `${siteUrl}${rikinHeadshot.src}`;

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: post.title,
  description: post.excerpt,
  datePublished: post.date,
  dateModified: post.date,
  author: {
    "@type": "Person",
    name: post.author,
    url: authorUrl,
    image: authorImageUrl,
    sameAs: [authorUrl],
  },
  publisher: {
    "@type": "Organization",
    name: "lowercase b2b",
    url: siteUrl,
  },
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": canonical,
  },
  keywords: post.tags.join(", "),
};
---
<BaseLayout title={`${post.title} | lowercase b2b`} description={post.excerpt}>
  <!-- HERO -->
  <section class="px-6 sm:px-12 lg:px-20 pt-32 sm:pt-48 pb-16">
    <nav aria-label="Breadcrumb" class="mb-8 font-mono text-[11px] tracking-[0.15em] uppercase">
      <a href="/writing" class="text-muted hover:text-ink transition">← Writing</a>
    </nav>
    <p class="font-mono text-[12px] tracking-[0.15em] text-muted uppercase flex items-center gap-2">
      <span class="w-1.5 h-1.5 rounded-full bg-accent shrink-0"></span>
      <span>{post.tags.join(" • ")}</span>
    </p>
    <h1 class="mt-6 max-w-[1040px]">{post.title}</h1>
    <p class="mt-6 max-w-[820px] text-[18px] leading-relaxed text-ink/80">{post.excerpt}</p>
    <div class="mt-8 flex items-center gap-3 font-mono text-[11px] tracking-[0.1em] text-muted uppercase">
      <a href={authorUrl} target="_blank" rel="noreferrer author" class="flex items-center gap-3 group">
        <Image src={rikinHeadshot} alt={post.author} width={32} height={32} class="w-8 h-8 rounded-full object-cover" />
        <span class="text-ink group-hover:text-accent transition">{post.author}</span>
      </a>
      <span>— {formatDate(post.date)} — {post.readTime}</span>
    </div>
  </section>

  <!-- ARTICLE + TOC + NEWSLETTER CARD -->
  <section class="px-6 sm:px-12 lg:px-20 pb-32">
    <div class="grid grid-cols-1 lg:grid-cols-[260px_1fr] gap-12 lg:gap-20">
      <aside class="lg:sticky lg:top-24 self-start space-y-8">
        <div>
          <p class="font-mono text-[11px] tracking-[0.15em] text-muted uppercase mb-4">— Contents</p>
          <nav class="post-toc flex flex-col space-y-2 font-mono text-[12px] tracking-tight">
            {post.toc.map((t) => (
              <a href={`#${t.id}`} data-toc={t.id} class="toc-link block py-1 text-[#404040] hover:text-ink transition">
                {t.label}
              </a>
            ))}
          </nav>
        </div>

        <aside class="bg-panel text-white p-6 rounded-sm">
          <p class="font-mono text-[10px] tracking-[0.15em] text-white/60 uppercase flex items-center gap-2">
            <span class="w-1.5 h-1.5 rounded-full bg-accent shrink-0"></span>
            <span>Newsletter</span>
          </p>
          <h3 class="mt-3 text-[20px] tracking-[-0.01em] font-light leading-snug">
            Get new posts in your inbox.
          </h3>
          <p class="mt-3 text-[13px] text-white/70 leading-relaxed">
            One note a month on B2B GTM — positioning, SEO, AI search, and the brands we admire.
          </p>
          <form class="email-capture mt-5 w-full" data-source={`${Astro.url.pathname}#newsletter-aside`} data-cal="https://cal.com/rikin-diwan/lowercase-intro">
            <label for={`newsletter-${post.slug}`} class="sr-only">Work email</label>
            <input
              id={`newsletter-${post.slug}`}
              type="email"
              name="email"
              required
              placeholder="emma@email.com"
              autocomplete="email"
              class="w-full bg-transparent border border-white/20 px-3 py-2.5 text-[13px] text-white placeholder:text-white/40 focus:outline-none focus:border-white rounded-sm"
            />
            <button
              type="submit"
              class="mt-2 w-full font-mono text-[10px] tracking-[0.15em] uppercase bg-white text-panel px-4 py-2.5 rounded-sm hover:opacity-90 transition disabled:opacity-60"
            >
              Subscribe
            </button>
          </form>
        </aside>
      </aside>

      <article class="max-w-[720px] space-y-16">
        {post.body.map((sec) => (
          <div id={sec.id} class="scroll-mt-24">
            <h2 class="text-[28px] sm:text-[32px] tracking-[-0.02em] font-light">{sec.heading}</h2>
            <div class="mt-6 space-y-5 text-[17px] leading-[1.7] text-ink/80">
              {sec.paragraphs.map((p) => <p>{p}</p>)}
            </div>
          </div>
        ))}
      </article>
    </div>
  </section>

  <!-- RELATED -->
  <section class="px-6 sm:px-12 lg:px-20 py-24 border-t border-line">
    <div class="flex justify-between items-baseline mb-12">
      <h2 class="text-[28px] sm:text-[36px] tracking-[-0.02em] font-light">More writing.</h2>
      <a href="/writing" class="font-mono text-[11px] tracking-[0.15em] text-muted hover:text-ink">— VIEW ALL</a>
    </div>
    <div class="grid gap-4 grid-cols-1 sm:grid-cols-2 lg:grid-cols-3">
      {related.map((p) => (
        <BlogPostCard
          slug={p.slug}
          title={p.title}
          excerpt={p.excerpt}
          date={p.date}
          readTime={p.readTime}
          tags={p.tags}
        />
      ))}
    </div>
  </section>

  <script type="application/ld+json" is:inline set:html={JSON.stringify(articleSchema)} />
</BaseLayout>

<script>
  const links = document.querySelectorAll<HTMLAnchorElement>(".toc-link");
  if (links.length) {
    const sections = Array.from(links)
      .map((l) => document.getElementById(l.dataset.toc || ""))
      .filter((el): el is HTMLElement => !!el);
    const setActive = (id: string) => {
      links.forEach((l) => {
        const active = l.dataset.toc === id;
        l.classList.toggle("text-accent", active);
        l.classList.toggle("text-[#404040]", !active);
      });
    };
    const io = new IntersectionObserver(
      (entries) => {
        const visible = entries.filter((e) => e.isIntersecting).sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);
        if (visible[0]) setActive(visible[0].target.id);
      },
      { rootMargin: "-30% 0px -60% 0px", threshold: 0 }
    );
    sections.forEach((s) => io.observe(s));
  }
</script>
