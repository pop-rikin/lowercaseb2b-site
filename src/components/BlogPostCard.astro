---
import { formatDate } from "../data/posts";

interface Props {
  slug: string;
  title: string;
  excerpt: string;
  date: string;
  readTime: string;
  tags: string[];
}

const { slug, title, excerpt, date, readTime, tags } = Astro.props;
---
<a
  href={`/writing/${slug}`}
  data-tags={tags.join("|")}
  class="post-card group flex flex-col border border-line rounded-sm bg-bg p-6 sm:p-7 hover:border-[#ffb380] transition"
>
  <div class="flex items-center gap-3 font-mono text-[11px] tracking-tight text-muted">
    <span class="w-1.5 h-1.5 rounded-full bg-accent"></span>
    <span class="uppercase tracking-[0.1em]">{tags[0]}</span>
    <span>•</span>
    <span>{formatDate(date)}</span>
  </div>
  <h3 class="mt-5 text-[20px] sm:text-[22px] tracking-[-0.01em] leading-snug font-light text-ink">
    {title}
  </h3>
  <p class="mt-3 text-[14px] text-ink/70 leading-relaxed line-clamp-3">{excerpt}</p>
  <p class="mt-6 font-mono text-[11px] tracking-tight text-muted group-hover:text-ink transition">
    {readTime} — Read post →
  </p>
</a>
